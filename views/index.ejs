<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <style>
        :root {
            color-scheme: dark;
            --bg: #141514;
            --panel: #232520;
            --panel-strong: #303327;
            --text: #f6f1e6;
            --muted: #b8b2a5;
            --accent: #d2a64f;
            --light: #e6d7b9;
            --dark: #6f7d55;
            --danger: #d86565;
            --success: #66d47e;
            --last: rgba(216, 169, 78, 0.55);
            --select: rgba(74, 144, 226, 0.55);
        }

        * {
            box-sizing: border-box;
        }

        body {
            margin: 0;
            min-height: 100vh;
            font-family: Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
            background: radial-gradient(circle at top left, #2d3327 0, var(--bg) 34rem);
            color: var(--text);
        }

        .app {
            min-height: 100vh;
            display: grid;
            grid-template-columns: minmax(18rem, 24rem) minmax(20rem, 38rem);
            gap: 2rem;
            align-items: center;
            justify-content: center;
            padding: 2rem;
        }

        .panel {
            background: color-mix(in srgb, var(--panel), transparent 8%);
            border: 1px solid rgba(255, 255, 255, 0.08);
            border-radius: 8px;
            padding: 1.25rem;
            box-shadow: 0 1.5rem 4rem rgba(0, 0, 0, 0.25);
        }

        h1 {
            margin: 0 0 0.5rem;
            font-size: clamp(2rem, 7vw, 3.8rem);
            line-height: 0.95;
            letter-spacing: 0;
        }

        .status {
            margin: 0.8rem 0 1rem;
            color: var(--muted);
            min-height: 1.5rem;
        }

        .meta {
            display: grid;
            grid-template-columns: repeat(2, minmax(0, 1fr));
            gap: 0.75rem;
            margin: 1.25rem 0;
        }

        .meta-item {
            background: var(--panel-strong);
            border-radius: 8px;
            padding: 0.75rem;
            min-height: 4.2rem;
        }

        .label {
            display: block;
            color: var(--muted);
            font-size: 0.75rem;
            text-transform: uppercase;
        }

        .value {
            display: block;
            margin-top: 0.3rem;
            font-weight: 700;
        }

        .actions {
            display: flex;
            gap: 0.75rem;
            flex-wrap: wrap;
        }

        button {
            border: 0;
            border-radius: 8px;
            padding: 0.75rem 1rem;
            font: inherit;
            font-weight: 700;
            color: #191714;
            background: var(--accent);
            cursor: pointer;
            min-height: 2.8rem;
            -webkit-tap-highlight-color: transparent;
        }

        button.secondary {
            color: var(--text);
            background: var(--panel-strong);
        }

        button:disabled {
            cursor: not-allowed;
            opacity: 0.55;
        }

        .seat-actions {
            display: grid;
            grid-template-columns: repeat(3, minmax(0, 1fr));
            gap: 0.5rem;
            margin-bottom: 0.75rem;
        }

        .seat-actions button {
            padding-inline: 0.6rem;
        }

        .message {
            margin-top: 1rem;
            min-height: 1.25rem;
            color: var(--danger);
            font-weight: 700;
        }

        .flash {
            position: fixed;
            top: 1rem;
            left: 50%;
            z-index: 20;
            transform: translateX(-50%) translateY(-140%);
            width: min(90vw, 30rem);
            border: 1px solid rgba(255, 255, 255, 0.14);
            border-radius: 8px;
            padding: 0.9rem 1rem;
            background: rgba(25, 24, 19, 0.94);
            box-shadow: 0 1rem 3rem rgba(0, 0, 0, 0.38);
            color: var(--text);
            font-weight: 900;
            text-align: center;
            text-transform: uppercase;
            opacity: 0;
            pointer-events: none;
            transition: transform 180ms ease, opacity 180ms ease;
        }

        .flash.show {
            transform: translateX(-50%) translateY(0);
            opacity: 1;
        }

        .flash.check {
            color: #171615;
            background: var(--accent);
        }

        .flash.game-over {
            color: white;
            background: #9f3030;
        }

        .flash.info {
            color: #142016;
            background: var(--success);
        }

        .board-wrap {
            width: min(88vw, 38rem);
            aspect-ratio: 1;
        }

        .chessboard {
            display: grid;
            grid-template-columns: repeat(8, minmax(0, 1fr));
            grid-template-rows: repeat(8, minmax(0, 1fr));
            width: 100%;
            height: 100%;
            border: 0.6rem solid #353526;
            border-radius: 8px;
            overflow: hidden;
            box-shadow: 0 2rem 5rem rgba(0, 0, 0, 0.35);
            touch-action: none;
        }

        .square {
            position: relative;
            display: flex;
            align-items: center;
            justify-content: center;
            user-select: none;
            cursor: pointer;
            -webkit-tap-highlight-color: transparent;
        }

        .square.light {
            background: var(--light);
        }

        .square.dark {
            background: var(--dark);
        }

        .square.selected::after,
        .square.last-move::after {
            content: "";
            position: absolute;
            inset: 0;
            pointer-events: none;
        }

        .square.selected::after {
            background: var(--select);
        }

        .square.last-move::after {
            background: var(--last);
        }

        .piece {
            position: relative;
            z-index: 1;
            border: 0;
            background: transparent;
            padding: 0;
            font-family: "Segoe UI Symbol", "Noto Sans Symbols", serif;
            font-size: clamp(2.1rem, 9vw, 4.4rem);
            line-height: 1;
            cursor: default;
            filter: drop-shadow(0 0.12rem 0.08rem rgba(0, 0, 0, 0.45));
        }

        .piece.playable {
            cursor: grab;
        }

        .piece.white {
            color: #fff8e7;
        }

        .piece.black {
            color: #171615;
        }

        .dragging {
            opacity: 0.45;
        }

        .promotion-backdrop {
            position: fixed;
            inset: 0;
            z-index: 30;
            display: none;
            align-items: center;
            justify-content: center;
            padding: 1rem;
            background: rgba(0, 0, 0, 0.62);
        }

        .promotion-backdrop.show {
            display: flex;
        }

        .promotion-dialog {
            width: min(92vw, 24rem);
            border: 1px solid rgba(255, 255, 255, 0.14);
            border-radius: 8px;
            padding: 1rem;
            background: var(--panel);
            box-shadow: 0 2rem 5rem rgba(0, 0, 0, 0.45);
        }

        .promotion-title {
            margin: 0 0 0.8rem;
            font-size: 1.1rem;
            font-weight: 900;
        }

        .promotion-options {
            display: grid;
            grid-template-columns: repeat(4, minmax(0, 1fr));
            gap: 0.55rem;
        }

        .promotion-option {
            display: grid;
            place-items: center;
            aspect-ratio: 1;
            padding: 0;
            color: var(--text);
            background: var(--panel-strong);
            font-family: "Segoe UI Symbol", "Noto Sans Symbols", serif;
            font-size: 2.3rem;
        }

        @media (max-width: 820px) {
            .app {
                grid-template-columns: 1fr;
                align-items: start;
                padding: 1rem;
            }

            .panel {
                order: 2;
            }

            .board-wrap {
                order: 1;
                justify-self: center;
                width: min(94vw, 34rem);
            }
        }

        @media (max-width: 520px) {
            .app {
                gap: 0.8rem;
                padding: 0.55rem;
            }

            .panel {
                padding: 0.9rem;
            }

            .board-wrap {
                width: min(96vw, 96svh);
            }

            .chessboard {
                border-width: 0.35rem;
            }

            .piece {
                font-size: clamp(1.9rem, 10vw, 3.8rem);
            }
        }
    </style>
</head>
<body>
    <div class="flash" id="flash" role="status" aria-live="assertive"></div>

    <div class="app">
        <section class="panel" aria-label="Game information">
            <h1>Chess</h1>
            <p class="status" id="status">Connecting...</p>

            <div class="meta">
                <div class="meta-item">
                    <span class="label">Your seat</span>
                    <span class="value" id="role">Connecting</span>
                </div>
                <div class="meta-item">
                    <span class="label">Players</span>
                    <span class="value" id="players">0 / 2</span>
                </div>
            </div>

            <div class="seat-actions" aria-label="Choose a seat">
                <button id="play-white" type="button" class="secondary">White</button>
                <button id="play-black" type="button" class="secondary">Black</button>
                <button id="watch" type="button" class="secondary">Watch</button>
            </div>

            <div class="actions">
                <button id="reset" type="button">New game</button>
                <button id="flip" type="button" class="secondary">Flip board</button>
            </div>

            <p class="message" id="message" aria-live="polite"></p>
        </section>

        <main class="board-wrap" aria-label="Chess board">
            <div class="chessboard" id="chessboard"></div>
        </main>
    </div>

    <div class="promotion-backdrop" id="promotion" aria-modal="true" role="dialog" aria-labelledby="promotion-title">
        <div class="promotion-dialog">
            <p class="promotion-title" id="promotion-title">Promote pawn</p>
            <div class="promotion-options">
                <button class="promotion-option" type="button" data-promotion="q" aria-label="Promote to queen"></button>
                <button class="promotion-option" type="button" data-promotion="r" aria-label="Promote to rook"></button>
                <button class="promotion-option" type="button" data-promotion="b" aria-label="Promote to bishop"></button>
                <button class="promotion-option" type="button" data-promotion="n" aria-label="Promote to knight"></button>
            </div>
        </div>
    </div>

    <script src="/socket.io/socket.io.js"></script>
    <script src="/js/chessgame.js"></script>
</body>
</html>
